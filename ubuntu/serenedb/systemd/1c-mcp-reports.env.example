# /etc/1c-mcp-reports.env  (600, секреты НЕ в git — это шаблон)
DEEPSEEK_API_KEY=sk-xxxxxxxx
# Бот-отчёты ходят под READ-ONLY ролью serene_ro (запись БД физически запрещена) — см. setup_ro_role.sql.
SERENEDB_DSN=host=127.0.0.1 port=7890 user=serene_ro dbname=postgres
PGPASSWORD=CHANGE_ME_RANDOM
MCP_HOST=127.0.0.1
MCP_PORT=6015
# Директория для PNG-графиков. ОБЯЗАТЕЛЬНО под workspace бота (разрешённая директория медиа),
# иначе движок откажет в доставке файла клиенту. Подставить своего бот-юзера:
CHART_DIR=/home/undebot/.openclaw/workspace/charts
# Семантический резолвер (Этап 3 v2): Qwen-эмбеддер РОВНО как braine (DashScope text-embedding-v4 @ 1536).
# Ключ/URL брать из braine .env (ALIBABA_*). Только Qwen, ollama не используем.
ALIBABA_API_KEY=sk-xxxxxxxx
ALIBABA_EMBED_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# EMBED_MODEL=text-embedding-v4   # дефолт
# EMBED_DIM=1536                  # дефолт (как в pgvector braine)
