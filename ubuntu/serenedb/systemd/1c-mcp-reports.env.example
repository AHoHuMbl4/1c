# /etc/1c-mcp-reports.env  (600, секреты НЕ в git — это шаблон)
DEEPSEEK_API_KEY=sk-xxxxxxxx
SERENEDB_DSN=host=127.0.0.1 port=7890 user=postgres
MCP_HOST=127.0.0.1
MCP_PORT=6015
# Директория для PNG-графиков. ОБЯЗАТЕЛЬНО под workspace бота (разрешённая директория медиа),
# иначе движок откажет в доставке файла клиенту. Подставить своего бот-юзера:
CHART_DIR=/home/undebot/.openclaw/workspace/charts
