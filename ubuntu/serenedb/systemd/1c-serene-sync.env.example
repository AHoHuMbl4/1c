# /etc/1c-serene-sync.env  (600, секреты НЕ в git — это шаблон)
# Синк витрины идёт под RW (postgres); резолвер эмбеддит на Qwen (ALIBABA_*, как braine).
SERENEDB_DSN=host=127.0.0.1 port=7890 user=postgres
ETL_ODATA_BASE=http://127.0.0.1:6011
CSV_DIR=/var/lib/serenedb
ALIBABA_API_KEY=sk-xxxxxxxx
ALIBABA_EMBED_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# SELECTED_FILE=/etc/1c-etl-selected.txt   # дефолт (те же галочки, что ETL)
